<Window x:Class="WaterMarkTool.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:vm="clr-namespace:WaterMarkTool.ViewModels"
        xmlns:models="clr-namespace:WaterMarkTool.Models"
        xmlns:conv="clr-namespace:WaterMarkTool.Converters"
        xmlns:primitives="clr-namespace:System.Windows.Controls.Primitives;assembly=PresentationFramework"
        mc:Ignorable="d"
        Title="图片水印工具"
        Width="1280"
        Height="820"
        MinWidth="1000"
        MinHeight="680"
        Background="{DynamicResource AppBackgroundBrush}">
    <Window.DataContext>
        <vm:MainViewModel />
    </Window.DataContext>

    <Window.Resources>
        <conv:BoolToVisibilityConverter x:Key="BoolToVisibility" />
        <conv:OpacityPercentConverter x:Key="OpacityPercent" />
        <conv:RotationDisplayConverter x:Key="RotationDisplay" />
        <conv:EnumDescriptionConverter x:Key="EnumDescription" />
        <ObjectDataProvider x:Key="PatternValues" MethodName="GetValues" ObjectType="{x:Type models:WatermarkPattern}">
            <ObjectDataProvider.MethodParameters>
                <x:Type TypeName="models:WatermarkPattern" />
            </ObjectDataProvider.MethodParameters>
        </ObjectDataProvider>
        <ObjectDataProvider x:Key="PositionValues" MethodName="GetValues" ObjectType="{x:Type models:WatermarkPosition}">
            <ObjectDataProvider.MethodParameters>
                <x:Type TypeName="models:WatermarkPosition" />
            </ObjectDataProvider.MethodParameters>
        </ObjectDataProvider>
    </Window.Resources>

    <Grid>
        <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <Grid Grid.Row="0" Margin="0,0,0,16">
            <StackPanel>
                <TextBlock Text="桌面图片水印工具" FontSize="24" FontWeight="Bold" Foreground="{DynamicResource AppTextBrush}" />
                <StackPanel Orientation="Horizontal" Margin="0,8,0,0">
                    <TextBlock Text="✓ 图片本地处理，不上传云端" Margin="0,0,20,0" Foreground="{DynamicResource AppSecondaryTextBrush}" />
                    <TextBlock Text="✓ 支持批量导入与打包导出" Margin="0,0,20,0" Foreground="{DynamicResource AppSecondaryTextBrush}" />
                    <TextBlock Text="✓ 适用于证件、照片、文档" Foreground="{DynamicResource AppSecondaryTextBrush}" />
                </StackPanel>
            </StackPanel>

            <Button HorizontalAlignment="Right"
                    VerticalAlignment="Top"
                    Style="{StaticResource SecondaryButton}"
                    Content="{Binding ThemeToggleLabel}"
                    Command="{Binding ToggleThemeCommand}" />
        </Grid>

        <Grid Grid.Row="1">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="360" />
                <ColumnDefinition Width="16" />
                <ColumnDefinition Width="*" />
            </Grid.ColumnDefinitions>

            <Border Grid.Column="0" Style="{StaticResource CardBorder}">
                <ScrollViewer VerticalScrollBarVisibility="Auto">
                    <StackPanel>
                        <TextBlock Style="{StaticResource SectionTitle}" Text="水印文字" />
                        <TextBox Text="{Binding Settings.Text, UpdateSourceTrigger=PropertyChanged}"
                                 AcceptsReturn="True"
                                 TextWrapping="Wrap"
                                 Height="72"
                                 MaxLength="200" />

                        <ItemsControl ItemsSource="{Binding Templates}" Margin="0,12,0,0">
                            <ItemsControl.ItemsPanel>
                                <ItemsPanelTemplate>
                                    <WrapPanel />
                                </ItemsPanelTemplate>
                            </ItemsControl.ItemsPanel>
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <Button Style="{StaticResource TemplateButton}"
                                            Content="{Binding Name}"
                                            Command="{Binding DataContext.ApplyTemplateCommand, RelativeSource={RelativeSource AncestorType=Window}}"
                                            CommandParameter="{Binding}" />
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>

                        <Grid Margin="0,12,0,0">
                            <CheckBox Content="导入时根据背景自动配色"
                                      IsChecked="{Binding AutoAdaptOnImport}"
                                      VerticalAlignment="Center" />
                            <Button Content="智能配色"
                                    HorizontalAlignment="Right"
                                    Style="{StaticResource SecondaryButton}"
                                    Padding="12,6"
                                    Command="{Binding AutoAdaptSettingsCommand}" />
                        </Grid>

                        <Separator Margin="0,16" Background="{DynamicResource AppBorderBrush}" />

                        <TextBlock Style="{StaticResource SectionTitle}" Text="布局方式" />
                        <ComboBox ItemsSource="{Binding Source={StaticResource PatternValues}}"
                                  SelectedItem="{Binding Pattern}">
                            <ComboBox.ItemTemplate>
                                <DataTemplate>
                                    <TextBlock Text="{Binding Converter={StaticResource EnumDescription}}"
                                               Foreground="{DynamicResource AppTextBrush}" />
                                </DataTemplate>
                            </ComboBox.ItemTemplate>
                        </ComboBox>

                        <StackPanel Margin="0,12,0,0" Visibility="{Binding ShowCountControl, Converter={StaticResource BoolToVisibility}}">
                            <TextBlock Style="{StaticResource FieldLabel}" Text="水印数量" />
                            <TextBox Text="{Binding Settings.WatermarkCount, UpdateSourceTrigger=PropertyChanged}" />
                        </StackPanel>

                        <StackPanel Margin="0,12,0,0" Visibility="{Binding ShowPositionControl, Converter={StaticResource BoolToVisibility}}">
                            <TextBlock Style="{StaticResource FieldLabel}" Text="位置" />
                            <ComboBox ItemsSource="{Binding Source={StaticResource PositionValues}}"
                                      SelectedItem="{Binding Settings.Position}">
                                <ComboBox.ItemTemplate>
                                    <DataTemplate>
                                        <TextBlock Text="{Binding Converter={StaticResource EnumDescription}}"
                                                   Foreground="{DynamicResource AppTextBrush}" />
                                    </DataTemplate>
                                </ComboBox.ItemTemplate>
                            </ComboBox>
                        </StackPanel>

                        <Separator Margin="0,16" Background="{DynamicResource AppBorderBrush}" />

                        <TextBlock Style="{StaticResource SectionTitle}" Text="字体与样式" />
                        <ComboBox ItemsSource="{Binding FontFamilies}"
                                  SelectedItem="{Binding Settings.FontFamily}" />

                        <StackPanel Orientation="Horizontal" Margin="0,10,0,0">
                            <ToggleButton Style="{StaticResource ToggleStyleButton}"
                                          Content="B"
                                          IsChecked="{Binding Settings.IsBold}" />
                            <ToggleButton Style="{StaticResource ToggleStyleButton}"
                                          Content="I"
                                          Margin="8,0,0,0"
                                          IsChecked="{Binding Settings.IsItalic}" />
                        </StackPanel>

                        <Grid Margin="0,16,0,0">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="12" />
                                <ColumnDefinition Width="*" />
                            </Grid.ColumnDefinitions>
                            <StackPanel Grid.Column="0">
                                <TextBlock Style="{StaticResource FieldLabel}" Text="颜色" />
                                <DockPanel>
                                    <Border x:Name="ColorPreview"
                                            Width="36"
                                            Height="36"
                                            CornerRadius="6"
                                            BorderBrush="{DynamicResource AppBorderBrush}"
                                            BorderThickness="1"
                                            Margin="0,0,8,0"
                                            Background="{Binding Settings.Color, Converter={x:Static conv:ColorToBrushConverter.Instance}}"
                                            MouseLeftButtonUp="ColorPreview_Click"
                                            Cursor="Hand" />
                                    <TextBox Text="{Binding Settings.Color, Converter={x:Static conv:ColorToHexConverter.Instance}, UpdateSourceTrigger=LostFocus}" />
                                </DockPanel>
                            </StackPanel>
                            <StackPanel Grid.Column="2">
                                <TextBlock Style="{StaticResource FieldLabel}">
                                    <Run Text="不透明度 " />
                                    <Run Text="{Binding Settings.Opacity, Converter={StaticResource OpacityPercent}}" />
                                </TextBlock>
                                <Slider Minimum="0.05" Maximum="1" Value="{Binding Settings.Opacity}" />
                            </StackPanel>
                        </Grid>

                        <Grid Margin="0,16,0,0">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="12" />
                                <ColumnDefinition Width="*" />
                            </Grid.ColumnDefinitions>
                            <StackPanel Grid.Column="0">
                                <TextBlock Style="{StaticResource FieldLabel}" Text="间隔" />
                                <Slider Minimum="0.5" Maximum="8" Value="{Binding Settings.Spacing}" />
                            </StackPanel>
                            <StackPanel Grid.Column="2">
                                <TextBlock Style="{StaticResource FieldLabel}" Text="字号" />
                                <Slider Minimum="0.3" Maximum="3" Value="{Binding Settings.Size}" />
                            </StackPanel>
                        </Grid>

                        <StackPanel Margin="0,16,0,0">
                            <TextBlock Style="{StaticResource FieldLabel}">
                                <Run Text="旋转角度 " />
                                <Run Text="{Binding Settings.Rotation, Converter={StaticResource RotationDisplay}}" />
                            </TextBlock>
                            <Slider Minimum="-90" Maximum="90" Value="{Binding Settings.Rotation}" />
                        </StackPanel>
                    </StackPanel>
                </ScrollViewer>
            </Border>

            <Border Grid.Column="2" Style="{StaticResource CardBorder}">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="*" />
                        <RowDefinition Height="Auto" />
                    </Grid.RowDefinitions>

                    <Border x:Name="DropZone"
                            Grid.Row="0"
                            BorderBrush="{DynamicResource AppPrimaryBrush}"
                            BorderThickness="2"
                            CornerRadius="10"
                            Padding="24"
                            Margin="0,0,0,16"
                            Background="#143B82F6"
                            AllowDrop="True"
                            Drop="DropZone_Drop"
                            DragOver="DropZone_DragOver"
                            DragLeave="DropZone_DragLeave"
                            MouseLeftButtonUp="DropZone_Click"
                            Cursor="Hand">
                        <StackPanel HorizontalAlignment="Center">
                            <TextBlock Text="📁" FontSize="28" HorizontalAlignment="Center" />
                            <TextBlock Text="点击或拖拽图片到此处上传"
                                       FontSize="16"
                                       FontWeight="SemiBold"
                                       Foreground="{DynamicResource AppTextBrush}"
                                       HorizontalAlignment="Center"
                                       Margin="0,8,0,4" />
                            <TextBlock Text="支持 jpg、jpeg、png、gif、webp、bmp、ico 格式，也可 Ctrl+V 粘贴图片"
                                       Foreground="{DynamicResource AppSecondaryTextBrush}"
                                       HorizontalAlignment="Center" />
                        </StackPanel>
                    </Border>

                    <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
                        <ItemsControl ItemsSource="{Binding Images}">
                            <ItemsControl.ItemsPanel>
                                <ItemsPanelTemplate>
                                    <primitives:UniformGrid Columns="3" />
                                </ItemsPanelTemplate>
                            </ItemsControl.ItemsPanel>
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <Border Margin="0,0,12,12"
                                            HorizontalAlignment="Stretch"
                                            BorderBrush="{DynamicResource AppBorderBrush}"
                                            BorderThickness="1"
                                            CornerRadius="10"
                                            Background="{DynamicResource AppBackgroundBrush}">
                                        <StackPanel>
                                            <Border Height="220"
                                                    Background="#111827"
                                                    CornerRadius="10,10,0,0"
                                                    Cursor="Hand"
                                                    MouseLeftButtonDown="Thumbnail_MouseLeftButtonDown">
                                                <Image Source="{Binding PreviewImage}"
                                                       Stretch="Uniform"
                                                       Margin="8"
                                                       IsHitTestVisible="False" />
                                            </Border>
                                            <TextBlock Text="{Binding FileName}"
                                                       Margin="10,8,10,0"
                                                       TextTrimming="CharacterEllipsis"
                                                       Foreground="{DynamicResource AppTextBrush}" />
                                            <StackPanel Orientation="Horizontal" Margin="10,8,10,10">
                                                <Button Content="复制"
                                                        Style="{StaticResource SecondaryButton}"
                                                        Padding="10,6"
                                                        Command="{Binding DataContext.CopyImageCommand, RelativeSource={RelativeSource AncestorType=Window}}"
                                                        CommandParameter="{Binding}" />
                                                <Button Content="下载"
                                                        Style="{StaticResource SecondaryButton}"
                                                        Padding="10,6"
                                                        Margin="6,0,0,0"
                                                        Command="{Binding DataContext.SaveImageCommand, RelativeSource={RelativeSource AncestorType=Window}}"
                                                        CommandParameter="{Binding}" />
                                                <Button Content="删除"
                                                        Style="{StaticResource SecondaryButton}"
                                                        Padding="10,6"
                                                        Margin="6,0,0,0"
                                                        Command="{Binding DataContext.RemoveImageCommand, RelativeSource={RelativeSource AncestorType=Window}}"
                                                        CommandParameter="{Binding}" />
                                            </StackPanel>
                                        </StackPanel>
                                    </Border>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </ScrollViewer>

                    <Grid Grid.Row="2" Margin="0,16,0,0">
                        <TextBlock Text="{Binding StatusText}"
                                   VerticalAlignment="Center"
                                   Foreground="{DynamicResource AppSecondaryTextBrush}" />
                        <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                            <Button Content="⬇️ 下载全部"
                                    Style="{StaticResource PrimaryButton}"
                                    Margin="0,0,8,0"
                                    Command="{Binding DownloadAllCommand}" />
                            <Button Content="🗑️ 删除全部"
                                    Style="{StaticResource SecondaryButton}"
                                    Command="{Binding DeleteAllCommand}" />
                        </StackPanel>
                    </Grid>

                    <Border Grid.RowSpan="3"
                            Background="#AAFFFFFF"
                            Visibility="{Binding IsProcessing, Converter={StaticResource BoolToVisibility}}">
                        <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center">
                            <TextBlock Text="正在处理图片..."
                                       FontSize="18"
                                       FontWeight="SemiBold"
                                       Foreground="{DynamicResource AppTextBrush}"
                                       HorizontalAlignment="Center" />
                        </StackPanel>
                    </Border>
                </Grid>
            </Border>
        </Grid>
        </Grid>

        <Grid Panel.ZIndex="100"
              Visibility="{Binding IsPreviewOpen, Converter={StaticResource BoolToVisibility}}"
              Background="#CC000000"
              MouseLeftButtonDown="PreviewOverlay_BackgroundClick">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <Grid Grid.Row="0" Margin="20,16,20,0">
            <TextBlock Text="{Binding PreviewFileName}"
                       Foreground="White"
                       FontSize="16"
                       FontWeight="SemiBold"
                       VerticalAlignment="Center" />
            <Button Content="✕"
                    HorizontalAlignment="Right"
                    Width="40"
                    Height="40"
                    FontSize="18"
                    Style="{StaticResource SecondaryButton}"
                    Command="{Binding ClosePreviewCommand}" />
        </Grid>

        <Grid Grid.Row="1" Margin="20,12">
            <Button Content="‹"
                    Width="48"
                    Height="48"
                    FontSize="28"
                    HorizontalAlignment="Left"
                    VerticalAlignment="Center"
                    Style="{StaticResource SecondaryButton}"
                    Command="{Binding PreviewPreviousCommand}" />
            <Image Source="{Binding PreviewImage}"
                   Stretch="Uniform"
                   MaxWidth="1000"
                   MaxHeight="640"
                   HorizontalAlignment="Center"
                   VerticalAlignment="Center"
                   Cursor="Hand"
                   MouseLeftButtonDown="PreviewImage_Click" />
            <Button Content="›"
                    Width="48"
                    Height="48"
                    FontSize="28"
                    HorizontalAlignment="Right"
                    VerticalAlignment="Center"
                    Style="{StaticResource SecondaryButton}"
                    Command="{Binding PreviewNextCommand}" />
        </Grid>

        <TextBlock Grid.Row="2"
                   Text="Esc 关闭  ·  ← → 切换图片  ·  再次点击图片关闭"
                   Foreground="#CCFFFFFF"
                   HorizontalAlignment="Center"
                   Margin="0,0,0,16" />
        </Grid>
    </Grid>
</Window>
